{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "terminal-zoo (debug)",
      "runtimeExecutable": "cargo",
      "runtimeArgs": ["run"]
    },
    {
      "name": "terminal-zoo (debug + backtrace)",
      "runtimeExecutable": "cargo",
      "runtimeArgs": ["run"],
      "env": {
        "RUST_BACKTRACE": "1"
      }
    },
    {
      "name": "terminal-zoo (release)",
      "runtimeExecutable": "cargo",
      "runtimeArgs": ["run", "--release"]
    }
  ]
}
